# Copy to .env.local and fill in. Also set these in Vercel project settings for production.

# Gmail account that sends the assessment-form notifications.
# Requires 2-Step Verification + an App Password: https://myaccount.google.com/apppasswords
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Optional: inbox that receives form submissions. Defaults to GMAIL_USER.
ASSESSMENT_TO_EMAIL=
