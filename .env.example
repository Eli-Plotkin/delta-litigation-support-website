# Copy to .env.local and fill in. Also set these in Vercel project settings for production.

# Resend API key (https://resend.com/api-keys) — server-only
RESEND_API_KEY=

# Inbox where assessment-form submissions are delivered (any address you read)
ASSESSMENT_TO_EMAIL=

# Sender address. Must be on a domain verified in Resend for production;
# omit to fall back to onboarding@resend.dev (testing only — can only send
# to the email on your Resend account).
NOTIFICATION_FROM_EMAIL="Delta Litigation Support <notifications@deltalitigationsupport.com>"
